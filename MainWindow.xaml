<Window
    x:Class="Next_Episode_3._0.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Next Episode">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <ScrollViewer>
            <Grid Padding="24" ColumnSpacing="24" RowSpacing="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- LEFT SIDE -->
                <StackPanel Grid.Column="0" Grid.Row="0" Spacing="18">

                    <!-- Show selection -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Selected show"
                                   FontSize="14"
                                   FontWeight="SemiBold" />

                        <!-- TODO: Fill with shows from ShowService -->
                        <ComboBox x:Name="ShowComboBox"
                                  PlaceholderText="Select a show"
                                  Width="360">
                            <ComboBoxItem Content="Attack on Titan" />
                            <ComboBoxItem Content="Hunter x Hunter" />
                            <ComboBoxItem Content="Jujutsu Kaisen" />
                        </ComboBox>
                    </StackPanel>

                    <!-- Current episode card -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="8">
                            <TextBlock Text="The next episode"
                                       FontSize="20"
                                       FontWeight="Bold" />

                            <!-- TODO: Replace placeholder text with selected show's current episode -->
                            <TextBlock x:Name="EpisodeTitleText"
                                       Text="Season 04, Episode 30"
                                       FontSize="15" />

                            <TextBlock x:Name="EpisodeDurationText"
                                       Text="Duration: 25m 00s"
                                       FontSize="14" />

                            <TextBlock x:Name="EpisodeFileText"
                                       Text="Attack.on.Titan.S04E30.1080p.BluRay.x265.mkv"
                                       TextWrapping="Wrap"
                                       FontStyle="Italic"
                                       FontSize="14" />
                        </StackPanel>
                    </Border>

                    <!-- Episode management -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="12">
                            <TextBlock Text="Episode Management"
                                       FontSize="18"
                                       FontWeight="SemiBold" />

                            <Grid ColumnSpacing="10" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- TODO: Play next episode and update progress -->
                                <Button x:Name="PlayNextEpisodeButton"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Content="Play next episode"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Skip current episode and update progress -->
                                <Button x:Name="SkipEpisodeButton"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Content="Skip episode"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Open popup/dialog to choose current episode -->
                                <Button x:Name="ChooseCurrentEpisodeButton"
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Content="Choose current episode"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Watch selected episode without changing progress -->
                                <Button x:Name="WatchSpecificEpisodeButton"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Content="Watch specific episode"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Go back to previous episode -->
                                <Button x:Name="PreviousEpisodeButton"
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Content="Previous episode"
                                        HorizontalAlignment="Stretch" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Recent activity -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="10">
                            <TextBlock Text="Recent Activity"
                                       FontSize="18"
                                       FontWeight="SemiBold" />

                            <!-- TODO: Fill with watch history -->
                            <ListView x:Name="RecentActivityList"
                                      Height="220">
                                <ListViewItem Content="Watched Hunter x Hunter S01E136" />
                                <ListViewItem Content="Watched Hunter x Hunter S01E135" />
                                <ListViewItem Content="Watched Jujutsu Kaisen S01E04" />
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT SIDE -->
                <StackPanel Grid.Column="1" Grid.Row="0" Spacing="18">

                    <!-- Poster -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="12">

                            <!-- TODO: Replace with downloaded poster filepath -->
                            <Image x:Name="PosterImage"
                                   Source="Assets/placeholder-poster.png"
                                   Height="320"
                                   Stretch="UniformToFill" />

                            <TextBlock x:Name="SelectedShowNameText"
                                       Text="Attack on Titan"
                                       HorizontalAlignment="Center"
                                       FontSize="20"
                                       FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <!-- Progress -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="10">
                            <TextBlock Text="Watch Progress"
                                       FontSize="18"
                                       FontWeight="SemiBold" />

                            <!-- TODO: Calculate progress from user show progress -->
                            <ProgressBar x:Name="WatchProgressBar"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="100"
                                         Height="18" />

                            <TextBlock x:Name="WatchProgressText"
                                       Text="100%"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold" />

                            <TextBlock x:Name="TimeWatchedText"
                                       Text="Time watched: 13h 27m"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Show management -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="12">
                            <TextBlock Text="Show Management"
                                       FontSize="18"
                                       FontWeight="SemiBold" />

                            <Grid ColumnSpacing="10" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- TODO: Open Add Show dialog and download poster -->
                                <Button x:Name="AddShowButton"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Content="Add show"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Open folder picker for new season -->
                                <Button x:Name="AddSeasonButton"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Content="Add season"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Open Show Manager page/dialog -->
                                <Button x:Name="ShowManagerButton"
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Content="Show manager"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Remove selected show -->
                                <Button x:Name="RemoveShowButton"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Content="Remove show"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Reset progress for selected show -->
                                <Button x:Name="ResetProgressButton"
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Content="Reset progress"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Set current episode back to first episode -->
                                <Button x:Name="RestartShowButton"
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Content="Restart show"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Later: automatic download feature -->
                                <Button x:Name="AutoDownloadButton"
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Content="Auto download"
                                        HorizontalAlignment="Stretch" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Statistics -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="10">
                            <TextBlock Text="Statistics"
                                       FontSize="18"
                                       FontWeight="SemiBold" />

                            <!-- TODO: Fill from StatisticsService -->
                            <TextBlock x:Name="StartedShowsText"
                                       Text="Started shows: 0" />

                            <TextBlock x:Name="FinishedShowsText"
                                       Text="Finished shows: 0" />

                            <TextBlock x:Name="WatchedEpisodesText"
                                       Text="Watched episodes: 0" />

                            <TextBlock x:Name="WatchedMinutesText"
                                       Text="Watched minutes: 0" />

                            <TextBlock x:Name="MostWatchedShowText"
                                       Text="Most watched show: -" />
                        </StackPanel>
                    </Border>

                    <!-- Settings / bonus -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="12">
                            <TextBlock Text="Settings"
                                       FontSize="18"
                                       FontWeight="SemiBold" />

                            <Grid ColumnSpacing="10" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- TODO: Open file picker for video player .exe -->
                                <Button x:Name="VideoPlayerButton"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Content="Video player"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Open player manager dialog -->
                                <Button x:Name="MultiplePlayersButton"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Content="Players"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Open style customization dialog -->
                                <Button x:Name="StyleButton"
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Content="Style"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Minimize app -->
                                <Button x:Name="MinimizeButton"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Content="Minimize"
                                        HorizontalAlignment="Stretch" />

                                <!-- TODO: Later bonus settings -->
                                <CheckBox x:Name="AutoSubtitleCheckBox"
                                          Grid.Row="2"
                                          Grid.Column="0"
                                          Content="Auto subtitles" />

                                <CheckBox x:Name="AutoAudioTrackCheckBox"
                                          Grid.Row="2"
                                          Grid.Column="1"
                                          Content="Auto audio" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Log output -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="10">
                            <TextBlock Text="Log Output"
                                       FontSize="18"
                                       FontWeight="SemiBold" />

                            <!-- TODO: Append application messages here -->
                            <TextBox x:Name="LogOutputTextBox"
                                     Height="120"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>